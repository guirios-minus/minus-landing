# ─────────────────────────────────────────────────────────────
# Minus Landing — Environment Variables
# Copy this file to .env.local and fill in the values.
# ─────────────────────────────────────────────────────────────

# ── Resend (contact form) ──────────────────────────────────────
# Get your API key at https://resend.com/api-keys
# Without this key the form still works in dev (logs to console).
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The email address that receives contact form submissions.
# Default: hello@minuspm.com
CONTACT_EMAIL=hello@minuspm.com

# The "From" address shown in the email.
# Use onboarding@resend.dev for testing (no domain needed).
# After verifying minuspm.com in Resend, switch to noreply@minuspm.com.
FROM_EMAIL=onboarding@resend.dev

# ── App URL (used in Navbar CTAs) ─────────────────────────────
# Default: https://app.minuspm.com
NEXT_PUBLIC_APP_URL=https://app.minuspm.com
